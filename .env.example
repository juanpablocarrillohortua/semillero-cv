# Semillero CV — Variables de Entorno
# Copia este archivo a .env y llena tus valores:
#   cp .env.example .env
#
# O usa export directo en terminal (recomendado en PCs compartidos):
#   export GEMINI_API_KEY="tu-key-aqui"

# Google Gemini (opcional — solo si usas Gemini CLI)
GEMINI_API_KEY=

# GitHub (opcional — para operaciones con repos)
GH_TOKEN=

# Identificador de equipo
TEAM_NAME=equipo-01
